# frontend
FRONTEND_EXTERNAL_PORT=5173

# backend-main
BACKEND_MAIN_EXTERNAL_PORT=8000
SHARED_MAIL_ATTACHMENT_DIR=/var/mail_attchment

# backend-mail
BACKEND_MAIL_EXTERNAL_PORT=8001
EMAIL_USERNAME=example@abc.com
EMAIL_PASSWORD=your_secret_password
IMAP_SERVER=imap.example.com
IMAP_PORT=993
SMTP_SERVER=smtp.example.com
SMTP_PORT=465
MAIL_CHECK_INTERVAL=60
CORS_ORIGINS=http://localhost:5173,http://example.com
LOG_LEVEL=INFO
PRODIGY_USERNAME=username
PRODIGY_PASSWORD=password
VSHIP_USERNAME=username
VSHIP_PASSWORD=password
BSM_USERNAME=username
BSM_PASSWORD=password

# db
DB_EXTERNAL_PORT=3306
DB_DATABASE=db
DB_PASSWORD=password

# 数据库邮件数据迁出
# ./export_emails.sh -m 2026-02 -e prod -o /mnt/d/db_email_backup/
# 邮件附件文件迁出
# docker run --rm -v ship-sale-prod_mail_attachment:/from -v /mnt/d/attachment_backup:/to alpine sh -c 'mv /from/2026/02 /to/2026/02'
